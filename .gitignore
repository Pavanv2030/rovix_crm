# CodeIgniter 4
writable/cache/*
writable/logs/*
writable/session/*
writable/uploads/*
writable/debugbar/*
!writable/cache/index.html
!writable/logs/index.html
!writable/session/index.html
!writable/uploads/index.html
!writable/debugbar/index.html

# Environment
.env
.env.local
.env.*.local

# Composer
vendor/
composer.lock

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
desktop.ini

# Node (if using frontend build tools)
node_modules/
npm-debug.log
yarn-error.log

# Build artifacts
public/build/
.gstack/

# Runtime data leaked into public/ during dev
public/writable/
public/test_db.php

# Audit docs with secret fragments — keep local, don't push public
SECURITY-AUDIT.md
